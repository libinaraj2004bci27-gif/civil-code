#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int marks_summation(int* marks, int number_of_students, char gender) {
    int sum = 0;
    // Boys are at even indices (0, 2, 4...), Girls are at odd (1, 3, 5...)
    int start_index = (gender == 'b') ? 0 : 1;
    
    for (int i = start_index; i < number_of_students; i += 2) {
        sum += *(marks + i); // Pointer arithmetic to access marks[i]
    }
    
    return sum;
}

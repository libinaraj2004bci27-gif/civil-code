#include <stdio.h>
#include <stdlib.h>
#include <math.h>

struct triangle
{
	int a;
	int b;
	int c;
};

typedef struct triangle triangle;
double get_area_sq(triangle tr) {
    double a = tr.a, b = tr.b, c = tr.c;
    return (a + b + c) * (b + c - a) * (a + c - b) * (a + b - c);
}

void sort_by_area(triangle* tr, int n) {
    // Bubble Sort implementation
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (get_area_sq(tr[j]) > get_area_sq(tr[j + 1])) {
                // Swap the triangle structures
                triangle temp = tr[j];
                tr[j] = tr[j + 1];
                tr[j + 1] = temp;
            }
        }
    }
}


 

int romanToInt(char* s) {
    // Helper to map Roman characters to their integer values
    int getValue(char c) {
        switch (c) {
            case 'I': return 1;
            case 'V': return 5;
            case 'X': return 10;
            case 'L': return 50;
            case 'C': return 100;
            case 'D': return 500;
            case 'M': return 1000;
            default: return 0;
        }
    }

    int total = 0;
    int length = strlen(s);

    for (int i = 0; i < length; i++) {
        int current = getValue(s[i]);
        
        // Peek at the next character
        if (i + 1 < length) {
            int next = getValue(s[i + 1]);
            
            // If the current value is less than the next, it's a subtractive case
            if (current < next) {
                total -= current;
            } else {
                total += current;
            }
        } else {
            // Last character is always added
            total += current;
        }
    }

    return total;
}

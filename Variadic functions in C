int sum(int count, ...) {
    int total = 0;
    va_list args;
    va_start(args, count);
    for (int i = 0; i < count; i++) {
        total += va_arg(args, int);
    }
    va_end(args);
    return total; // MUST return the value
}

int min(int count, ...) {
    int min_val = INT_MAX;
    va_list args;
    va_start(args, count);
    for (int i = 0; i < count; i++) {
        int current = va_arg(args, int);
        if (current < min_val) {
            min_val = current;
        }
    }
    va_end(args);
    return min_val; // MUST return the value
}

int max(int count, ...) {
    int max_val = INT_MIN;
    va_list args;
    va_start(args, count);
    for (int i = 0; i < count; i++) {
        int current = va_arg(args, int);
        if (current > max_val) {
            max_val = current;
        }
    }
    va_end(args);
    return max_val; // MUST return the value
}


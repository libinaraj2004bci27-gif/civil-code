#include <stdio.h>
#include <stdlib.h>
#include <string.h>

/**
 * Swaps two string pointers
 */
void swap(char **s, int i, int j) {
    char *tmp = s[i];
    s[i] = s[j];
    s[j] = tmp;
}

/**
 * Reverses a portion of the string array from start to end
 */
void reverse(char **s, int start, int end) {
    while (start < end) {
        swap(s, start++, end--);
    }
}

int next_permutation(int n, char **s) {
    // 1. Find the rightmost pivot: first s[i] < s[i+1]
    int i = n - 2;
    while (i >= 0 && strcmp(s[i], s[i + 1]) >= 0) {
        i--;
    }

    // If no pivot is found, the array is in descending order
    if (i < 0) return 0;

    // 2. Find the rightmost successor to pivot: first s[j] > s[i]
    int j = n - 1;
    while (strcmp(s[j], s[i]) <= 0) {
        j--;
    }

    // 3. Swap the pivot and successor
    swap(s, i, j);

    // 4. Reverse the suffix starting after the pivot
    reverse(s, i + 1, n - 1);

    return 1;
}

#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    
    int n;
    scanf("%d", &n);
    
    int sum = 0;
    
    // Logic to extract digits
    // We loop while n is greater than 0
    while (n > 0) {
        sum += (n % 10); // Get the last digit and add to sum
        n = n / 10;      // Remove the last digit from n
    }
    
    printf("%d\n", sum);
    
    return 0;
}

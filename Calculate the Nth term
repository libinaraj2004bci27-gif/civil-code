#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

// Recursive function to find the nth term
int find_nth_term(int n, int a, int b, int c) {
    // Base Case 1: If n is 1, return the first term
    if (n == 1) {
        return a;
    }
    // Base Case 2: If n is 2, return the second term
    if (n == 2) {
        return b;
    }
    // Base Case 3: If n is 3, return the third term
    if (n == 3) {
        return c;
    }

    /* 
       Recursive Step:
       The nth term is the sum of the (n-1)th, (n-2)th, and (n-3)th terms.
    */
    return find_nth_term(n - 1, a, b, c) + 
           find_nth_term(n - 2, a, b, c) + 
           find_nth_term(n - 3, a, b, c);
}

int main() {
    int n, a, b, c;
  
    // Read n and the first three terms a, b, c
    scanf("%d", &n);
    scanf("%d %d %d", &a, &b, &c);
    
    // Call the recursive function and print the result
    int ans = find_nth_term(n, a, b, c);
    printf("%d\n", ans); 
    
    return 0;
}


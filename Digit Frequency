#include <stdio.h>
#include <string.h>
#include <stdlib.h>

int main() {
    // 1. Allocate space for the input string (max 1000 characters)
    char *s = malloc(1024 * sizeof(char));
    scanf("%s", s);

    // 2. Initialize a frequency array for digits 0-9 with zeros
    int counts[10] = {0};

    // 3. Iterate through the string
    for (int i = 0; s[i] != '\0'; i++) {
        // Check if the current character is a digit
        if (s[i] >= '0' && s[i] <= '9') {
            /* 
               Convert character to integer index:
               Subtracting '0' from a character digit gives its integer value.
               e.g., '5' - '0' = 5
            */
            counts[s[i] - '0']++;
        }
    }

    // 4. Print the frequencies separated by spaces
    for (int i = 0; i < 10; i++) {
        printf("%d ", counts[i]);
    }
    printf("\n");

    // 5. Clean up memory
    free(s);
    
    return 0;
}

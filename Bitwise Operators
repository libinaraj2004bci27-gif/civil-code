#include <stdio.h>

void calculate_the_maximum(int n, int k) {
    int max_and = 0;
    int max_or = 0;
    int max_xor = 0;

    // Outer loop for 'a' from 1 up to n
    for (int a = 1; a <= n; a++) {
        // Inner loop for 'b' from a + 1 up to n (ensures a < b)
        for (int b = a + 1; b <= n; b++) {
            
            int current_and = a & b;
            int current_or  = a | b;
            int current_xor = a ^ b;

            // Check AND: must be greater than current max AND less than k
            if (current_and < k && current_and > max_and) {
                max_and = current_and;
            }

            // Check OR: must be greater than current max AND less than k
            if (current_or < k && current_or > max_or) {
                max_or = current_or;
            }

            // Check XOR: must be greater than current max AND less than k
            if (current_xor < k && current_xor > max_xor) {
                max_xor = current_xor;
            }
        }
    }

    // Print results in the required order
    printf("%d\n%d\n%d\n", max_and, max_or, max_xor);
}

int main() {
    int n, k;
  
    // Reading input values for n and k
    if (scanf("%d %d", &n, &k) == 2) {
        calculate_the_maximum(n, k);
    }
    
    return 0;
}
